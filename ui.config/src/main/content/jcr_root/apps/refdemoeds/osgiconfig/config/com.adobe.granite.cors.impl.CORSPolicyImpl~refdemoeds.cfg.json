{
  "supportscredentials":false,
  "supportedmethods":[
    "GET",
    "HEAD",
    "OPTIONS",
    "POST"
  ],
  "alloworiginregexp":[
    "^https:\\/\\/[^/]+\\.aem\\.live$",
    "^https:\\/\\/[^/]+\\.aem\\.page$",
    "^https:\\/\\/[^/]+\\.hlx\\.live$",
    "^https:\\/\\/[^/]+\\.hlx\\.page$",
    "https://localhost:.*",
    "http://localhost:.*"
  ],
  "maxage": 1800,
  "supportedheaders":[
    "Origin",
    "Accept",
    "X-Requested-With",
    "Content-Type",
    "Access-Control-Request-Method",
    "Access-Control-Request-Headers",
    "Authorization"
  ],
  "allowedpaths":[
    "/api/assets/.*",
    "/content/dam/.*\\.json",
    "/content/dam/.*\\.[0-9]+\\.json",
    "/bin/querybuilder\\.json"
  ]
}